# Vercel Project Settings → Environment Variables (never commit real values)
#
# Use Neon's *pooled* connection string for serverless (hostname contains "-pooler"
# or append ?pgbouncer=true&connect_timeout=15 to the URL).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DATABASE?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"
CLIENT_URL="http://localhost:5173"
PUBLIC_SITE_URL="http://localhost:5173"

# Optional: automatic Facebook/Instagram posting (Settings → Organization can also store these)
SOCIAL_POSTING_ENABLED="false"
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""

# AI Copywriter — Groq (https://console.groq.com)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Optional fallback
OPENAI_API_KEY=""
